{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "description": "Deploys the HaloPSA Teams Notification Bot — Flex Consumption Function App + Bot Service + Teams channel + bot code (downloaded from a GitHub release at deploy time)."
    },
    "parameters": {
        "appName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "metadata": {
                "description": "Base name for all resources (e.g. haloxteams). Must be globally unique as it becomes the Function App hostname. Use only lowercase letters, digits, and hyphens; must start with a letter and end with a letter or digit. Underscores are not allowed."
            }
        },
        "microsoftAppId": {
            "type": "string",
            "metadata": {
                "description": "Application (Client) ID from your Azure AD App Registration."
            }
        },
        "microsoftAppPassword": {
            "type": "securestring",
            "metadata": {
                "description": "Client secret value from your Azure AD App Registration."
            }
        },
        "packageUrl": {
            "type": "string",
            "defaultValue": "https://github.com/Renada-Solutions/Teams-Adaptive-Cards/releases/latest/download/bot.zip",
            "metadata": {
                "description": "URL to the bot.zip package. Default points at the latest release of this template repo. Override only if forking."
            }
        }
    },
    "variables": {
        "storageAccountName": "[take(replace(replace(toLower(concat('st', parameters('appName'))), '-', ''), '_', ''), 24)]",
        "planName": "[concat(parameters('appName'), '-plan')]",
        "deploymentContainerName": "deployments",
        "deployIdentityName": "[concat(parameters('appName'), '-deploy-id')]",
        "deployScriptName": "[concat(parameters('appName'), '-deploy-code')]",
        "websiteContributorRoleId": "de139f84-1756-47ae-9be6-808fbbe84772",
        "roleAssignmentName": "[guid(resourceGroup().id, variables('deployIdentityName'), 'WebsiteContributor')]",
        "notifySecret": "[guid(resourceGroup().id, 'notifySecret')]"
    },
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('storageAccountName')]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "minimumTlsVersion": "TLS1_2",
                "allowBlobPublicAccess": false
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2023-05-01",
            "name": "[concat(variables('storageAccountName'), '/default/', variables('deploymentContainerName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
            ]
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2023-12-01",
            "name": "[variables('planName')]",
            "location": "[resourceGroup().location]",
            "kind": "functionapp",
            "sku": {
                "tier": "FlexConsumption",
                "name": "FC1"
            },
            "properties": {
                "reserved": true
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2023-12-01",
            "name": "[parameters('appName')]",
            "location": "[resourceGroup().location]",
            "kind": "functionapp,linux",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('storageAccountName'), 'default', variables('deploymentContainerName'))]",
                "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
                "httpsOnly": true,
                "siteConfig": {
                    "ftpsState": "Disabled",
                    "http20Enabled": true,
                    "minTlsVersion": "1.3",
                    "scmMinTlsVersion": "1.3",
                    "appSettings": [
                        {
                            "name": "AzureWebJobsStorage",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';EndpointSuffix=', environment().suffixes.storage, ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
                        },
                        {
                            "name": "MicrosoftAppId",
                            "value": "[parameters('microsoftAppId')]"
                        },
                        {
                            "name": "MicrosoftAppPassword",
                            "value": "[parameters('microsoftAppPassword')]"
                        },
                        {
                            "name": "MicrosoftAppTenantId",
                            "value": "[subscription().tenantId]"
                        },
                        {
                            "name": "NOTIFY_SECRET",
                            "value": "[variables('notifySecret')]"
                        }
                    ]
                },
                "functionAppConfig": {
                    "deployment": {
                        "storage": {
                            "type": "blobContainer",
                            "value": "[concat('https://', variables('storageAccountName'), '.blob.', environment().suffixes.storage, '/', variables('deploymentContainerName'))]",
                            "authentication": {
                                "type": "StorageAccountConnectionString",
                                "storageAccountConnectionStringName": "AzureWebJobsStorage"
                            }
                        }
                    },
                    "scaleAndConcurrency": {
                        "maximumInstanceCount": 40,
                        "instanceMemoryMB": 2048
                    },
                    "runtime": {
                        "name": "node",
                        "version": "24"
                    }
                }
            }
        },
        {
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
            "apiVersion": "2023-01-31",
            "name": "[variables('deployIdentityName')]",
            "location": "[resourceGroup().location]"
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[variables('roleAssignmentName')]",
            "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployIdentityName'))]"
            ],
            "properties": {
                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', variables('websiteContributorRoleId'))]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployIdentityName')), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Resources/deploymentScripts",
            "apiVersion": "2023-08-01",
            "name": "[variables('deployScriptName')]",
            "location": "[resourceGroup().location]",
            "kind": "AzureCLI",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('appName'))]",
                "[resourceId('Microsoft.Authorization/roleAssignments', variables('roleAssignmentName'))]"
            ],
            "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                    "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('deployIdentityName'))]": {}
                }
            },
            "properties": {
                "azCliVersion": "2.61.0",
                "timeout": "PT15M",
                "retentionInterval": "P1D",
                "cleanupPreference": "OnSuccess",
                "environmentVariables": [
                    { "name": "PACKAGE_URL", "value": "[parameters('packageUrl')]" },
                    { "name": "RG", "value": "[resourceGroup().name]" },
                    { "name": "APP_NAME", "value": "[parameters('appName')]" }
                ],
                "scriptContent": "set -e\necho \"Downloading $PACKAGE_URL...\"\ncurl -L --fail -o /tmp/bot.zip \"$PACKAGE_URL\"\nls -la /tmp/bot.zip\necho \"Waiting for Function App to be ready...\"\nfor i in $(seq 1 30); do\n  STATE=$(az functionapp show --resource-group \"$RG\" --name \"$APP_NAME\" --query state -o tsv 2>/dev/null || echo Pending)\n  echo \"  state=$STATE (attempt $i)\"\n  [ \"$STATE\" = \"Running\" ] && break\n  sleep 10\ndone\necho \"Deploying package to $APP_NAME...\"\naz functionapp deployment source config-zip --resource-group \"$RG\" --name \"$APP_NAME\" --src /tmp/bot.zip\necho \"Done.\""
            }
        },
        {
            "type": "Microsoft.BotService/botServices",
            "apiVersion": "2022-09-15",
            "name": "[parameters('appName')]",
            "location": "global",
            "sku": {
                "name": "F0"
            },
            "kind": "azurebot",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
            ],
            "properties": {
                "displayName": "[parameters('appName')]",
                "endpoint": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appName'))).defaultHostName, '/api/messages')]",
                "msaAppId": "[parameters('microsoftAppId')]",
                "msaAppTenantId": "[subscription().tenantId]",
                "msaAppType": "SingleTenant"
            }
        },
        {
            "type": "Microsoft.BotService/botServices/channels",
            "apiVersion": "2022-09-15",
            "name": "[concat(parameters('appName'), '/MsTeamsChannel')]",
            "location": "global",
            "dependsOn": [
                "[resourceId('Microsoft.BotService/botServices', parameters('appName'))]"
            ],
            "properties": {
                "channelName": "MsTeamsChannel",
                "properties": {
                    "isEnabled": true
                }
            }
        }
    ],
    "outputs": {
        "webhookUrl": {
            "type": "string",
            "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appName'))).defaultHostName, '/api/notify')]",
            "metadata": {
                "description": "The webhook URL to configure in HaloPSA (POST endpoint)."
            }
        },
        "messagingEndpoint": {
            "type": "string",
            "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appName'))).defaultHostName, '/api/messages')]",
            "metadata": {
                "description": "The Bot Framework messaging endpoint."
            }
        },
        "microsoftAppId": {
            "type": "string",
            "value": "[parameters('microsoftAppId')]",
            "metadata": {
                "description": "Use this App ID in your Teams manifest.json for the id and botId fields."
            }
        },
        "teamsManifestInstructions": {
            "type": "string",
            "value": "[concat('Update manifest.json id and botId to \"', parameters('microsoftAppId'), '\", zip with color.png and outline.png, upload to Teams as a custom app.')]"
        }
    }
}
