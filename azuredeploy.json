{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "description": "Deploys the HaloPSA Teams Notification Bot — Azure Function App, Bot Service, and Teams channel."
    },
    "parameters": {
        "appName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "metadata": {
                "description": "Base name for all resources (e.g. halopsa-ooh-bot). Must be globally unique as it becomes the Function App hostname. Use only lowercase letters, digits, and hyphens; must start with a letter and end with a letter or digit. Underscores are not allowed."
            }
        },
        "microsoftAppId": {
            "type": "string",
            "metadata": {
                "description": "Application (Client) ID from your Azure AD App Registration."
            }
        },
        "microsoftAppPassword": {
            "type": "securestring",
            "metadata": {
                "description": "Client secret value from your Azure AD App Registration."
            }
        },
        "repoUrl": {
            "type": "string",
            "defaultValue": "https://github.com/Renada-Solutions/Teams-Adaptive-Cards",
            "metadata": {
                "description": "GitHub repository URL containing the bot code."
            }
        },
        "repoBranch": {
            "type": "string",
            "defaultValue": "main",
            "metadata": {
                "description": "GitHub branch to deploy from."
            }
        }
    },
    "variables": {
        "storageAccountName": "[take(replace(replace(toLower(concat('st', parameters('appName'))), '-', ''), '_', ''), 24)]",
        "planName": "[concat(parameters('appName'), '-plan')]",
        "notifySecret": "[guid(resourceGroup().id, 'notifySecret')]"
    },
    "resources": [
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-05-01",
            "name": "[variables('storageAccountName')]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2"
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2023-12-01",
            "name": "[variables('planName')]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Y1",
                "tier": "Dynamic"
            },
            "properties": {
                "reserved": false
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2023-12-01",
            "name": "[parameters('appName')]",
            "location": "[resourceGroup().location]",
            "kind": "functionapp",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
                "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]"
            ],
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
                "httpsOnly": true,
                "siteConfig": {
                    "nodeVersion": "~24",
                    "use32BitWorkerProcess": false,
                    "ftpsState": "Disabled",
                    "http20Enabled": true,
                    "minTlsVersion": "1.3",
                    "scmMinTlsVersion": "1.3",
                    "appSettings": [
                        {
                            "name": "AzureWebJobsStorage",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';EndpointSuffix=', environment().suffixes.storage, ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
                        },
                        {
                            "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
                            "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';EndpointSuffix=', environment().suffixes.storage, ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value)]"
                        },
                        {
                            "name": "WEBSITE_CONTENTSHARE",
                            "value": "[toLower(replace(parameters('appName'), '_', '-'))]"
                        },
                        {
                            "name": "FUNCTIONS_EXTENSION_VERSION",
                            "value": "~4"
                        },
                        {
                            "name": "FUNCTIONS_WORKER_RUNTIME",
                            "value": "node"
                        },
                        {
                            "name": "WEBSITE_NODE_DEFAULT_VERSION",
                            "value": "~24"
                        },
                        {
                            "name": "PROJECT",
                            "value": "bot"
                        },
                        {
                            "name": "MicrosoftAppId",
                            "value": "[parameters('microsoftAppId')]"
                        },
                        {
                            "name": "MicrosoftAppPassword",
                            "value": "[parameters('microsoftAppPassword')]"
                        },
                        {
                            "name": "MicrosoftAppTenantId",
                            "value": "[subscription().tenantId]"
                        },
                        {
                            "name": "NOTIFY_SECRET",
                            "value": "[variables('notifySecret')]"
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Web/sites/sourcecontrols",
            "apiVersion": "2023-12-01",
            "name": "[concat(parameters('appName'), '/web')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
            ],
            "properties": {
                "repoUrl": "[parameters('repoUrl')]",
                "branch": "[parameters('repoBranch')]",
                "isManualIntegration": true
            }
        },
        {
            "type": "Microsoft.BotService/botServices",
            "apiVersion": "2022-09-15",
            "name": "[parameters('appName')]",
            "location": "global",
            "sku": {
                "name": "F0"
            },
            "kind": "azurebot",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('appName'))]"
            ],
            "properties": {
                "displayName": "[parameters('appName')]",
                "endpoint": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appName'))).defaultHostName, '/api/messages')]",
                "msaAppId": "[parameters('microsoftAppId')]",
                "msaAppTenantId": "[subscription().tenantId]",
                "msaAppType": "SingleTenant"
            }
        },
        {
            "type": "Microsoft.BotService/botServices/channels",
            "apiVersion": "2022-09-15",
            "name": "[concat(parameters('appName'), '/MsTeamsChannel')]",
            "location": "global",
            "dependsOn": [
                "[resourceId('Microsoft.BotService/botServices', parameters('appName'))]"
            ],
            "properties": {
                "channelName": "MsTeamsChannel",
                "properties": {
                    "isEnabled": true
                }
            }
        }
    ],
    "outputs": {
        "webhookUrl": {
            "type": "string",
            "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appName'))).defaultHostName, '/api/notify')]",
            "metadata": {
                "description": "The webhook URL to configure in HaloPSA (POST endpoint)."
            }
        },
        "messagingEndpoint": {
            "type": "string",
            "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', parameters('appName'))).defaultHostName, '/api/messages')]",
            "metadata": {
                "description": "The Bot Framework messaging endpoint."
            }
        },
        "microsoftAppId": {
            "type": "string",
            "value": "[parameters('microsoftAppId')]",
            "metadata": {
                "description": "Use this App ID in your Teams manifest.json for the id and botId fields."
            }
        },
        "teamsManifestInstructions": {
            "type": "string",
            "value": "[concat('Update manifest.json id and botId to \"', parameters('microsoftAppId'), '\", zip with color.png and outline.png, upload to Teams as a custom app.')]"
        }
    }
}
